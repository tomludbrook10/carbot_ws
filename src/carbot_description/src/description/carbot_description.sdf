<?xml version="1.0"?>
<sdf version="1.8" xmlns:xacro="http://www.ros.org/wiki/xacro">
<model name="carbot">

<!-- Define robot constants -->
<xacro:property name="base_length" value="0.230"/>
<xacro:property name="base_width" value="0.037"/>
<xacro:property name="base_height" value="0.050"/>

<!-- Front Axis -->
<xacro:property name="front_axle_length" value="0.005"/>
<xacro:property name="front_axle_width" value="0.130"/>
<xacro:property name="front_axle_height" value="0.005"/>

<!-- Back Axis -->
<xacro:property name="back_axle_length" value="0.005"/>
<xacro:property name="back_axle_width" value="0.180"/>
<xacro:property name="back_axle_height" value="0.005"/>

<!-- Steering link -->
<xacro:property name="steering_tire_link_radius" value="0.005"/>
<xacro:property name="steering_tire_link_length" value="0.020"/>
<xacro:property name="steering_angle_limit" value ="0.436332"/>
<xacro:property name="steering_velocity_limit" value ="1"/>

<!-- Tire constants -->
<xacro:property name="tire_radius" value="0.049"/>
<xacro:property name="tire_width" value="0.037"/>

<!-- Kinematic constants -->
<xacro:property name="wheel_separation" value="0.170"/>
<xacro:property name="kingpin_width" value="0.130"/>
<xacro:property name="wheel_base" value="0.178"/>

<!-- Define inertial property macros  -->
<xacro:macro name="box_inertia" params="m w h d">
  <inertial>
    <pose>0 0 0 ${pi/2} 0 ${pi/2}</pose>
    <mass>${m}</mass>
    <inertia>
      <ixx>${(m/12) * (h*h + d*d)}</ixx>
      <ixy>0.0</ixy>
      <ixz>0.0</ixz>
      <iyy>${(m/12) * (w*w + d*d)}</iyy>
      <iyz>0.0</iyz>
      <izz>${(m/12) * (w*w + h*h)}</izz>
    </inertia>
  </inertial>
</xacro:macro>

<xacro:macro name="cylinder_inertia" params="m r h">
  <inertial>
    <pose>0 0 0 ${pi/2} 0 0</pose>
    <mass>${m}</mass>
    <inertia>
      <ixx>${(m/12) * (3*r*r + h*h)}</ixx>
      <ixy>0</ixy>
      <ixz>0</ixz>
      <iyy>${(m/12) * (3*r*r + h*h)}</iyy>
      <iyz>0</iyz>
      <izz>${(m/2) * (r*r)}</izz>
    </inertia>
  </inertial>
</xacro:macro>

<!-- Main Chassis -->
<link name="base_link">
  <pose>0 0 0 0 0 0</pose>
  <visual name="base_link_visual">
    <geometry>
      <box>
        <size>${base_length} ${base_width} ${base_height}</size>
      </box>
    </geometry>
    <material>
      <ambient>0 1.0 1.0 1.0</ambient>
      <diffuse>0 1.0 1.0 1.0</diffuse>
    </material>
  </visual>
  <collision name="base_link_collision">
    <geometry>
      <box>
        <size>${base_length} ${base_width} ${base_height}</size>
      </box>
    </geometry>
  </collision>
  <xacro:box_inertia m="0.8" w="${base_width}" d="${base_length}" h="${base_height}"/>
</link>

<!-- Robot Footprint -->
<link name="base_footprint">
  <pose relative_to="base_link">0.0 0.0 ${-(0.040 + tire_radius)} 0 0 0</pose>
</link>

<joint name="base_joint" type="fixed">
  <parent>base_link</parent>
  <child>base_footprint</child>
</joint>

<!-- Front Axle -->
<link name="front_axle_link">
  <pose relative_to="base_link">0.075 0 -0.040 0 0 0</pose>
  <visual name="front_axle_link_visual">
    <geometry>
      <box>
        <size>${front_axle_length} ${front_axle_width} ${front_axle_height}</size>
      </box>
    </geometry>
    <material>
      <ambient>1.0 0 0 1.0</ambient>
      <diffuse>1.0 0 0 1.0</diffuse>
    </material>
  </visual>
  <collision name="front_axle_link_collision">
    <geometry>
      <box>
        <size>${front_axle_length} ${front_axle_width} ${front_axle_height}</size>
      </box>
    </geometry>
  </collision>
  <xacro:box_inertia m="0.2" w="${front_axle_width}" d="${front_axle_length}" h="${front_axle_height}"/>
</link>

<joint name="front_axle_joint" type="fixed">
  <parent>base_link</parent>
  <child>front_axle_link</child>
</joint>

<!-- Back Axle -->
<link name="back_axle_link">
  <pose relative_to="base_link">-0.103 0 -0.040 0 0 0</pose>
  <visual name="back_axle_link_visual">
    <geometry>
      <box>
        <size>${back_axle_length} ${back_axle_width} ${back_axle_height}</size>
      </box>
    </geometry>
    <material>
      <ambient>1.0 0 0 1.0</ambient>
      <diffuse>1.0 0 0 1.0</diffuse>
    </material>
  </visual>
  <collision name="back_axle_collision">
    <geometry>
      <box>
        <size>${back_axle_length} ${back_axle_width} ${back_axle_height}</size>
      </box>
    </geometry>
  </collision>
  <xacro:box_inertia m="0.4" w="${back_axle_width}" d="${back_axle_length}" h="${back_axle_height}"/>
</link>

<joint name="back_axle_joint" type="fixed">
  <parent>base_link</parent>
  <child>back_axle_link</child>
</joint>

<!-- Front Left Steering Link -->
<link name="front_left_steering_link">
  <pose relative_to="front_axle_link">0 0.065 0 0 0 0</pose>
  <visual name="front_left_steering_visual">
    <pose>0 ${steering_tire_link_length/2} 0 ${pi / 2} 0 0</pose>
    <geometry>
      <cylinder>
        <radius>${steering_tire_link_radius}</radius>
        <length>${steering_tire_link_length}</length>
      </cylinder>
    </geometry>
    <material>
      <ambient>0.0 0 1.0 1.0</ambient>
      <diffuse>0.0 0 1.0 1.0</diffuse>
    </material>
  </visual>
</link>

<joint name="front_left_steering_joint" type="revolute">
  <parent>front_axle_link</parent>
  <child>front_left_steering_link</child>
  <axis>
    <xyz>0 0 1</xyz>
    <limit>
      <lower>${-steering_angle_limit}</lower>
      <upper>${steering_angle_limit}</upper>
      <effort>10</effort>
      <velocity>1</velocity>
    </limit>
  </axis>
</joint>

<!-- Front Left Wheel -->
<link name="front_left_wheel_link">
  <pose relative_to="front_left_steering_link">0 ${steering_tire_link_length/2} 0 0 0 0</pose>
  <visual name="front_left_wheel_link_visual">
    <pose>0 0 0 ${pi / 2} 0 0</pose>
    <geometry>
      <cylinder>
        <radius>${tire_radius}</radius>
        <length>${tire_width}</length>
      </cylinder>
    </geometry>
    <material>
      <ambient>0.0 1.0 0.0 1.0</ambient>
      <diffuse>0.0 1.0 0.0 1.0</diffuse>
    </material>
  </visual>
  <collision name="front_left_wheel_link_collision">
    <pose>0 0 0 ${pi / 2} 0 0</pose>
    <geometry>
      <cylinder>
        <radius>${tire_radius}</radius>
        <length>${tire_width}</length>
      </cylinder>
    </geometry>
  </collision>
  <xacro:cylinder_inertia m="0.05" r="${tire_radius}" h="${tire_width}"/>
</link>

<joint name="front_left_wheel_joint" type="revolute">
  <parent>front_left_steering_link</parent>
  <child>front_left_wheel_link</child>
  <axis>
    <xyz>0 1 0</xyz>
       <limit>
            <lower>-inf</lower>
            <upper>inf</upper>
          </limit>
  </axis>
</joint>

<!-- Front Right Steering Link -->
<link name="front_right_steering_link">
  <pose relative_to="front_axle_link">0 -0.065 0 0 0 0</pose>
  <visual name="front_right_steering_link_visual">
    <pose>0 ${-steering_tire_link_length/2} 0 ${-pi / 2} 0 0</pose>
    <geometry>
      <cylinder>
        <radius>${steering_tire_link_radius}</radius>
        <length>${steering_tire_link_length}</length>
      </cylinder>
    </geometry>
    <material>
      <ambient>0.0 0 1.0 1.0</ambient>
      <diffuse>0.0 0 1.0 1.0</diffuse>
    </material>
  </visual>
</link>

<joint name="front_right_steering_joint" type="revolute">
  <parent>front_axle_link</parent>
  <child>front_right_steering_link</child>
  <axis>
    <xyz>0 0 1</xyz>
    <limit>
      <lower>${-steering_angle_limit}</lower>
      <upper>${steering_angle_limit}</upper>
      <effort>10</effort>
      <velocity>1</velocity>
    </limit>
  </axis>
</joint>

<!-- Front Right Wheel -->
<link name="front_right_wheel_link">
  <pose relative_to="front_right_steering_link">0 ${-steering_tire_link_length/2} 0 0 0 0</pose>
  <visual name="front_right_wheel_link_visual">
    <pose>0 0 0 ${-pi / 2} 0 0</pose>
    <geometry>
      <cylinder>
        <radius>${tire_radius}</radius>
        <length>${tire_width}</length>
      </cylinder>
    </geometry>
    <material>
      <ambient>0.0 1.0 0.0 1.0</ambient>
      <diffuse>0.0 1.0 0.0 1.0</diffuse>
    </material>
  </visual>
  <collision name="front_right_wheel_link_collision">
    <pose>0 0 0 ${-pi / 2} 0 0</pose>
    <geometry>
      <cylinder>
        <radius>${tire_radius}</radius>
        <length>${tire_width}</length>
      </cylinder>
    </geometry>
  </collision>
  <xacro:cylinder_inertia m="0.05" r="${tire_radius}" h="${tire_width}"/>
</link>

<joint name="front_right_wheel_joint" type="revolute">
  <parent>front_right_steering_link</parent>
  <child>front_right_wheel_link</child>
  <axis>
    <xyz>0 1 0</xyz>
    <limit>
      <lower>-inf</lower>
      <upper>inf</upper>
    </limit>
  </axis>
</joint>

<!-- Back Left Wheel -->
<link name="back_left_wheel_link">
  <pose relative_to="back_left_wheel_joint"> 0 0 0 0 0 0 </pose>
  <visual name="back_left_wheel_link_visual">
    <pose>0 0 0 ${pi / 2} 0 0</pose>
    <geometry>
      <cylinder>
        <radius>${tire_radius}</radius>
        <length>${tire_width}</length>
      </cylinder>
    </geometry>
    <material>
      <ambient>0.0 1.0 0.0 1.0</ambient>
      <diffuse>0.0 1.0 0.0 1.0</diffuse>
    </material>
  </visual>
  <collision name="back_left_wheel_link_collision">
    <pose>0 0 0 ${pi / 2} 0 0</pose>
    <geometry>
      <cylinder>
        <radius>${tire_radius}</radius>
        <length>${tire_width}</length>
      </cylinder>
    </geometry>
  </collision>
  <xacro:cylinder_inertia m="0.05" r="${tire_radius}" h="${tire_width}"/>
</link>

<joint name="back_left_wheel_joint" type="revolute">
  <parent>back_axle_link</parent>
  <child>back_left_wheel_link</child>
  <pose relative_to="back_axle_link">0 ${back_axle_width/2} 0 0 0 0</pose>
  <axis>
    <xyz>0 1 0</xyz>
      <limit>
            <lower>-inf</lower>
            <upper>inf</upper>
          </limit>
  </axis>
</joint>

<!-- Back Right Wheel -->
<link name="back_right_wheel_link">
 <pose relative_to="back_right_wheel_joint"> 0 0 0 0 0 0 </pose>
  <visual name="back_right_wheel_link_visual">
    <pose relative_to="">0 0 0 ${-pi / 2} 0 0</pose>
    <geometry>
      <cylinder>
        <radius>${tire_radius}</radius>
        <length>${tire_width}</length>
      </cylinder>
    </geometry>
    <material>
      <ambient>0.0 1.0 0.0 1.0</ambient>
      <diffuse>0.0 1.0 0.0 1.0</diffuse>
    </material>
  </visual>
  <collision name="back_right_wheel_link_collision">
    <pose>0 0 0 ${-pi / 2} 0 0</pose>
    <geometry>
      <cylinder>
        <radius>${tire_radius}</radius>
        <length>${tire_width}</length>
      </cylinder>
    </geometry>
  </collision>
  <xacro:cylinder_inertia m="0.05" r="${tire_radius}" h="${tire_width}"/>
</link>

<joint name="back_right_wheel_joint" type="revolute">
  <parent>back_axle_link</parent>
  <child>back_right_wheel_link</child>
   <pose relative_to="back_axle_link">0 ${-back_axle_width/2} 0 0 0 0</pose>
  <axis>
    <xyz>0 1 0</xyz>
       <limit>
            <lower>-inf</lower>
            <upper>inf</upper>
          </limit>
  </axis>
</joint>

<!-- IMU Sensor -->
<joint name="imu_joint" type="fixed">
  <parent>base_link</parent>
  <child>imu_link</child>
  <pose relative_to="base_link"> 0.0 0.0 0.01 0 0 0 </pose>
</joint>

<link name="imu_link">
  <pose relative_to="imu_joint"/>
  <visual name="imu_link_visual">
    <geometry>
      <box>
        <size>0.01 0.01 0.01</size>
      </box>
    </geometry>
    <material>
      <ambient>0.5 0.5 0.5 1.0</ambient>
      <diffuse>0.5 0.5 0.5 1.0</diffuse>
    </material>
  </visual>
  <collision name="imu_link_collision">
    <geometry>
      <box>
        <size>0.01 0.01 0.01</size>
      </box>
    </geometry>
  </collision>
  <xacro:box_inertia m="0.01" w="0.01" d="0.01" h="0.01"/>
  
  <sensor name="imu_sensor" type="imu">
    <always_on>true</always_on>
    <update_rate>100</update_rate>
    <visualize>true</visualize>
    <topic>/imu</topic>
    <gz_frame_id>imu_link</gz_frame_id>
    <imu>
      <angular_velocity>
        <x>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean>
            <bias_stddev>0.0000008</bias_stddev>
          </noise>
        </x>
        <y>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean>
            <bias_stddev>0.0000008</bias_stddev>
          </noise>
        </y>
        <z>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>2e-4</stddev>
            <bias_mean>0.0000075</bias_mean>
            <bias_stddev>0.0000008</bias_stddev>
          </noise>
        </z>
      </angular_velocity>
      <linear_acceleration>
        <x>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean>
            <bias_stddev>0.001</bias_stddev>
          </noise>
        </x>
        <y>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean>
            <bias_stddev>0.001</bias_stddev>
          </noise>
        </y>
        <z>
          <noise type="gaussian">
            <mean>0.0</mean>
            <stddev>1.7e-2</stddev>
            <bias_mean>0.1</bias_mean>
            <bias_stddev>0.001</bias_stddev>
          </noise>
        </z>
      </linear_acceleration>
    </imu>
  </sensor>
</link>

<!-- Ackermann Steering Plugin -->
<plugin filename="gz-sim-ackermann-steering-system" name="gz::sim::systems::AckermannSteering">
  <!-- wheels -->
  <left_joint>back_left_wheel_joint</left_joint>
  <right_joint>back_right_wheel_joint</right_joint>
  
  <!-- steering joints -->
  <left_steering_joint>front_left_steering_joint</left_steering_joint>
  <right_steering_joint>front_right_steering_joint</right_steering_joint>
  
  <!-- kinematics -->
  <wheel_separation>${wheel_separation}</wheel_separation>
  <kingpin_width>${kingpin_width}</kingpin_width>
  <wheel_base>${wheel_base}</wheel_base>
  <wheel_radius>${tire_radius}</wheel_radius>
  
  <!-- limits -->
  <max_steer>${steering_angle_limit}</max_steer>
  <max_speed>2</max_speed>
  
  <!-- input -->
  <topic>/demo/cmd_vel</topic>
  
  <!-- output -->
  <odom_topic>/demo/odom</odom_topic>
  <tf_topic>/tf</tf_topic>
  
  <frame_id>odom</frame_id>
  <child_frame_id>base_link</child_frame_id>
</plugin>


<link name="lidar_link">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.125"/>
    <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
  </inertial>

  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.0508" length="0.055"/>
    </geometry>
  </collision>

  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.0508" length="0.055"/>
    </geometry>
  </visual>
</link>

<joint name="lidar_joint" type="fixed">
  <parent link="base_link"/>
  <child link="lidar_link"/>
  <origin xyz="0 0 0.12" rpy="0 0 0"/>
</joint>




<plugin
  filename="gz-sim-joint-state-publisher-system"
  name="gz::sim::systems::JointStatePublisher">
  <topic>joint_states</topic>
</plugin>

</model>
</sdf>