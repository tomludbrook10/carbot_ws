<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="carbot">

<!-- Define robot constants -->
<xacro:property name="base_length" value="0.230"/>
<xacro:property name="base_width" value="0.037"/>
<xacro:property name="base_height" value="0.050"/>

<!-- Front Axis -->
<xacro:property name="front_axle_length" value="0.005"/>
<xacro:property name="front_axle_width" value="0.130"/>
<xacro:property name="front_axle_height" value="0.005"/>

<!-- Back Axis -->
<xacro:property name="back_axle_length" value="0.005"/>
<xacro:property name="back_axle_width" value="0.180"/>
<xacro:property name="back_axle_height" value="0.005"/>

<!-- Steering link -->
<xacro:property name="steering_tire_link_radius" value="0.005"/>
<xacro:property name="steering_tire_link_length" value="0.020"/>
<xacro:property name="steering_angle_limit" value ="0.436332"/>
<xacro:property name="steering_velocity_limit" value ="1"/>

<!-- Tire constants -->
<xacro:property name="tire_radius" value="0.049"/>
<xacro:property name="tire_width" value="0.037"/>

<!-- Define inertial property macros  -->
<xacro:macro name="box_inertia" params="m w h d">
<inertial>
    <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
    <mass value="${m}"/>
    <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0" iyy="${(m/12) * (w*w + d*d)}" iyz="0.0" izz="${(m/12) * (w*w + h*h)}"/>
</inertial>
</xacro:macro>

<xacro:macro name="cylinder_inertia" params="m r h">
<inertial>
    <origin xyz="0 0 0" rpy="${pi/2} 0 0" />
    <mass value="${m}"/>
    <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy = "0" ixz = "0" iyy="${(m/12) * (3*r*r + h*h)}" iyz = "0" izz="${(m/2) * (r*r)}"/>
</inertial>
</xacro:macro>




<!-- Main Chassie -->
<link name="base_link">
<visual>
    <geometry>
    <box size="${base_length} ${base_width} ${base_height}"/>
    </geometry>
    <material name="Cyan">
    <color rgba="0 1.0 1.0 1.0"/>
    </material>
</visual>
<collision>
    <geometry>
    <box size="${base_length} ${base_width} ${base_height}"/>
    </geometry>
</collision>
<xacro:box_inertia m="0.8" w="${base_width}" d="${base_length}" h="${base_height}"/>
</link>

  <!-- Robot Footprint -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0.0 0.0 ${-(0.040 + tire_radius)}" rpy="0 0 0"/>
  </joint>


<link name="front_axle_link">
<visual>
    <geometry>
    <box size="${front_axle_length} ${front_axle_width} ${front_axle_height}"/>
    </geometry>
    <material name="Red">
    <color rgba="1.0 0 0 1.0"/>
    </material>
</visual>
<collision>
    <geometry>
    <box size="${front_axle_length} ${front_axle_width} ${front_axle_height}"/>
    </geometry>
</collision>
<xacro:box_inertia m="0.2" w="${base_width}" d="${base_length}" h="${base_height}"/>
</link>

<joint name="front_axle_joint" type="fixed">
      <parent link="base_link"/>
      <child link="front_axle_link"/>
      <origin xyz="0.075 0 -0.040" rpy="0 0 0"/>
</joint>


<link name="back_axle_link">
<visual>
    <geometry>
    <box size="${back_axle_length} ${back_axle_width} ${back_axle_height}"/>
    </geometry>
    <material name="Red">
    <color rgba="1.0 0 0 1.0"/>
    </material>
</visual>
<collision>
    <geometry>
    <box size="${back_axle_length} ${back_axle_width} ${back_axle_height}"/>
    </geometry>
</collision>
<xacro:box_inertia m="0.4" w="${base_width}" d="${base_length}" h="${base_height}"/>
</link>

<joint name="back_axle_joint" type="fixed">
      <parent link="base_link"/>
      <child link="back_axle_link"/>
      <origin xyz="-0.103 0 -0.040" rpy="0 0 0"/>
</joint>

<!-- Front left Wheel -->
<link name="front_left_steering_link">
<visual>
    <origin xyz="0 ${steering_tire_link_length/2} 0" rpy="${pi / 2} 0 0"/>
    <geometry>
        <cylinder radius="${steering_tire_link_radius}" length="${steering_tire_link_length}"/>
    </geometry>
    <material name="Blue">
    <color rgba="0.0 0 1.0 1.0"/>
    </material>
</visual>

</link>

<joint name="front_left_streeing_joint" type="revolute">
      <parent link="front_axle_link"/>
      <child link="front_left_steering_link"/>
      <origin xyz="0 0.065 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
       <limit lower="${-steering_angle_limit}" upper="${steering_angle_limit}" effort="10" velocity="1"/>
</joint>

<link name="front_left_wheel_link">
<visual>
    <origin xyz="0 0 0" rpy="${pi / 2} 0 0"/>
    <geometry>
        <cylinder radius="${tire_radius}" length="${tire_width}"/>
    </geometry>
    <material name="Green">
    <color rgba="0.0 1.0 1.0 1.0"/>
    </material>
</visual>
<collision>
    <origin xyz="0 0 0" rpy="${pi / 2} 0 0"/>
    <geometry>
        <cylinder radius="${tire_radius}" length="${tire_width}"/>
    </geometry>
</collision>
  <xacro:cylinder_inertia m="0.05" r="${tire_radius}" h="${tire_width}"/>
</link>

<joint name="front_left_wheel_joint" type="continuous">
      <parent link="front_left_steering_link"/>
      <child link="front_left_wheel_link"/>
      <origin xyz="0 ${steering_tire_link_length/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
</joint>



<!-- Front Right Wheel -->
<link name="front_right_steering_link">
<visual>
    <origin xyz="0 ${-steering_tire_link_length/2} 0" rpy="${-pi / 2} 0 0"/>
    <geometry>
        <cylinder radius="${steering_tire_link_radius}" length="${steering_tire_link_length}"/>
    </geometry>
    <material name="Blue">
    <color rgba="0.0 0 1.0 1.0"/>
    </material>
</visual>
</link>

<joint name="front_right_streeing_joint" type="revolute">
      <parent link="front_axle_link"/>
      <child link="front_right_steering_link"/>
      <origin xyz="0 -0.065 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
       <limit lower="${-steering_angle_limit}" upper="${steering_angle_limit}" effort="10" velocity="1"/>
</joint>

<link name="front_right_wheel_link">
<visual>
    <origin xyz="0 0 0" rpy="${-pi / 2} 0 0"/>
    <geometry>
        <cylinder radius="${tire_radius}" length="${tire_width}"/>
    </geometry>
    <material name="Green">
    <color rgba="0.0 1.0 1.0 1.0"/>
    </material>
</visual>
<collision>
      <origin xyz="0 0 0" rpy="${-pi / 2} 0 0"/>
    <geometry>
        <cylinder radius="${tire_radius}" length="${tire_width}"/>
    </geometry>
</collision>
 <xacro:cylinder_inertia m="0.05" r="${tire_radius}" h="${tire_width}"/>
</link>

<joint name="front_right_wheel_joint" type="continuous">
      <parent link="front_right_steering_link"/>
      <child link="front_right_wheel_link"/>
      <origin xyz="0 ${-steering_tire_link_length/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
</joint>


<!-- Back Left Wheel -->
<link name="back_left_wheel_link">
<visual>
    <origin xyz="0 0 0" rpy="${pi / 2} 0 0"/>
    <geometry>
        <cylinder radius="${tire_radius}" length="${tire_width}"/>
    </geometry>
    <material name="Green">
    <color rgba="0.0 1.0 1.0 1.0"/>
    </material>
</visual>
<collision>
     <origin xyz="0 0 0" rpy="${pi / 2} 0 0"/>
    <geometry>
        <cylinder radius="${tire_radius}" length="${tire_width}"/>
    </geometry>
</collision>
 <xacro:cylinder_inertia m="0.05" r="${tire_radius}" h="${tire_width}"/>
</link>

<joint name="back_left_wheel_joint" type="continuous">
      <parent link="back_axle_link"/>
      <child link="back_left_wheel_link"/>
      <origin xyz="0 ${back_axle_width/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
</joint>


<!-- Back Right Wheel -->
<link name="back_right_wheel_link">
<visual>
    <origin xyz="0 0 0" rpy="${-pi / 2} 0 0"/>
    <geometry>
        <cylinder radius="${tire_radius}" length="${tire_width}"/>
    </geometry>
    <material name="Green">
    <color rgba="0.0 1.0 1.0 1.0"/>
    </material>
</visual>
<collision>
     <origin xyz="0 0 0" rpy="${-pi / 2} 0 0"/>
    <geometry>
        <cylinder radius="${tire_radius}" length="${tire_width}"/>
    </geometry>
</collision>
 <xacro:cylinder_inertia m="0.05" r="${tire_radius}" h="${tire_width}"/>
</link>

<joint name="back_right_wheel_joint" type="continuous">
      <parent link="back_axle_link"/>
      <child link="back_right_wheel_link"/>
      <origin xyz="0 ${-back_axle_width/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
</joint>


</robot>